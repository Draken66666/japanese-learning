# Server Configuration
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-in-production

# Admin Key (for payment verification)
ADMIN_KEY=your-admin-key-change-in-production

# Payment Mode: 'qrcode' (simple QR code, no merchant account) or 'api' (full API integration)
PAYMENT_MODE=qrcode

# QR Code Mode: Set your personal collection QR code URLs
# Upload your WeChat/Alipay collection QR code image and set the URL here
WECHAT_PAY_QR_URL=
ALIPAY_QR_URL=

# Auto-activate premium on payment confirmation (less secure, but simpler)
# Set to 'true' for instant activation, 'false' for manual verification
PAYMENT_AUTO_ACTIVATE=true

# === API Mode Configuration (optional, requires merchant accounts) ===
# WeChat Pay
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_KEY=
# WECHAT_NOTIFY_URL=

# Alipay
# ALIPAY_APP_ID=
# ALIPAY_MERCHANT_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=
# ALIPAY_RETURN_URL=
